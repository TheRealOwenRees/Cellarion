# Required secrets - copy to .env and set real values
JWT_SECRET=change-me-to-a-strong-random-string
MEILI_MASTER_KEY=change-me-to-a-strong-random-string

# Optional overrides (defaults shown)
# MONGO_URI=mongodb://mongo:27017/winecellar
# JWT_EXPIRES_IN=7d
# PORT=5000
# FRONTEND_URL=http://localhost        # set to your domain in production, e.g. https://cellarion.app
# MEILI_URL=http://meilisearch:7700
# REMBG_URL=http://rembg:5000

# Mailgun — optional. If unset, email verification is skipped (users log in immediately after registration).
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_FROM=Cellarion <no-reply@mg.yourdomain.com>
# MAILGUN_API_URL=https://api.mailgun.net    # EU region: https://api.eu.mailgun.net
