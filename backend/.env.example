# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/winecellar

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-in-production
MEILI_SEARCH_KEY=

# ── Vector Database (Qdrant) ──────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Image Processing ─────────────────────────────────────────────────────────
REMBG_URL=http://rembg:5000

# ── Email (Mailgun) — optional, email verification disabled without these ────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
MAILGUN_API_URL=

# ── AI Services — optional ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# ── Super Admin — optional ───────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_IPS=

# ── Web Push Notifications — optional ────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ── Stripe Payments — optional ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUPPORTER_PRICE_ID=
STRIPE_PATRON_PRICE_ID=

# ── Logging & Auditing ───────────────────────────────────────────────────────
LOG_LEVEL=info
AUDIT_TTL_DAYS=365

# ── SEO — optional ───────────────────────────────────────────────────────────
INDEXNOW_KEY=
